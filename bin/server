#!/usr/bin/env bash
# Run lovely-server with hot-reload.
#
# Best-case dev loop (install both tools once):
#
#     cargo install cargo-watch systemfd
#
# Then `./bin/server` will:
#   * keep the listening socket bound across rebuilds (systemfd) so the
#     browser doesn't hit "connection refused" while cargo recompiles;
#   * rebuild + restart on any Rust source / migration / Cargo.toml
#     change.
#
# `static/` is intentionally NOT in the watch list — those are served
# from disk by tower-http::ServeDir, so a CSS or JS edit only needs a
# browser refresh, no Rust rebuild.
#
# Falls back gracefully when one or both tools are missing.

set -euo pipefail

cd "$(dirname "$0")/.."

if [ -f .env ]; then
  set -a
  # shellcheck disable=SC1091
  . ./.env
  set +a
fi

# Sensible dev defaults if not set externally:
: "${LOVELY_DATABASE_URL:=postgres://lovely_rs:lovely_rs@localhost:5432/lovely_rs}"
: "${LOVELY_BIND:=0.0.0.0:8080}"
: "${LOVELY_BASE_URL:=http://localhost:8080}"
: "${LOVELY_LOG_LEVEL:=info,sqlx::query=warn}"

# Generate an ephemeral secret if not provided.
: "${LOVELY_SESSION_SECRET:=$(openssl rand -hex 32)}"

export LOVELY_DATABASE_URL LOVELY_BIND LOVELY_BASE_URL LOVELY_LOG_LEVEL LOVELY_SESSION_SECRET

have_watch=false
have_systemfd=false
command -v cargo-watch >/dev/null 2>&1 && have_watch=true
command -v systemfd    >/dev/null 2>&1 && have_systemfd=true

watch_args=(-q -w crates -w migrations -w Cargo.toml -w Cargo.lock)

if $have_watch && $have_systemfd; then
  # Full hot-reload: systemfd binds the socket, hands it to cargo-watch's
  # subprocess via env vars, lovely-server picks it up via listenfd.
  exec systemfd --no-pid -s "http::${LOVELY_BIND}" -- \
    cargo watch "${watch_args[@]}" -x 'run -p lovely-server'
fi

if $have_watch; then
  echo "==> Tip: install systemfd for socket-preserving hot-reload (\`cargo install systemfd\`)"
  exec cargo watch "${watch_args[@]}" -x 'run -p lovely-server'
fi

echo "==> Tip: install cargo-watch + systemfd for hot-reload"
echo "    cargo install cargo-watch systemfd"
exec cargo run -p lovely-server
