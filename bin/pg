#!/usr/bin/env bash
# Ensure the Homebrew Postgres service is running and that the
# `lovely` role and database exist. Idempotent: safe to re-run.
# Tails the Postgres log when ready.

set -euo pipefail

SERVICE="${LOVELY_PG_SERVICE:-postgresql@17}"
ROLE="${LOVELY_PG_ROLE:-lovely_rs}"
PASSWORD="${LOVELY_PG_PASSWORD:-lovely_rs}"
DB="${LOVELY_PG_DB:-lovely_rs}"
LOG="${LOVELY_PG_LOG:-/opt/homebrew/var/log/${SERVICE}.log}"

if ! command -v brew >/dev/null 2>&1; then
  echo "!! Homebrew not found. Install it or update LOVELY_PG_* env vars." >&2
  exit 1
fi

STATUS=$(brew services list | awk -v s="$SERVICE" '$1 == s {print $2}')
if [ "$STATUS" != "started" ]; then
  echo "==> Starting $SERVICE via brew services"
  brew services start "$SERVICE" >/dev/null
fi

echo "==> Waiting for Postgres to accept connections..."
for _ in $(seq 1 30); do
  if psql postgres -tAc 'select 1' >/dev/null 2>&1; then
    break
  fi
  sleep 0.5
done
psql postgres -tAc 'select 1' >/dev/null 2>&1 || {
  echo "!! Postgres did not become reachable within 15s" >&2
  exit 1
}

if [ "$(psql postgres -tAc "SELECT 1 FROM pg_roles WHERE rolname = '$ROLE'")" != "1" ]; then
  echo "==> Creating role $ROLE"
  psql postgres -c "CREATE ROLE $ROLE LOGIN PASSWORD '$PASSWORD' SUPERUSER" >/dev/null
fi
if [ "$(psql postgres -tAc "SELECT 1 FROM pg_database WHERE datname = '$DB'")" != "1" ]; then
  echo "==> Creating database $DB"
  psql postgres -c "CREATE DATABASE $DB OWNER $ROLE" >/dev/null
else
  psql postgres -c "ALTER DATABASE $DB OWNER TO $ROLE" >/dev/null
fi

echo "==> Ready: postgres://$ROLE:***@localhost:5432/$DB"

if [ -f "$LOG" ]; then
  echo "==> Tailing $LOG (Ctrl-C to detach; service stays running)"
  exec tail -F "$LOG"
else
  echo "==> Log not found at $LOG. Service is running; this tab is now idle."
  exec bash
fi
