# lovely-rs local environment template.
#
# Copy this file to .env, fill in real values, then run with:
#
#     LOVELY_DOTENV=1 cargo run -p lovely-server
#
# Never commit the populated .env (see .gitignore). Production deployments
# pass these via Docker secrets / Kubernetes Secrets — see deploy/README.md.

# --- HTTP server -----------------------------------------------------------

# Listen address. Use 127.0.0.1:8080 if you only want loopback access.
LOVELY_BIND=0.0.0.0:8080

# Public-facing base URL. Used to build OAuth redirect URIs and absolute
# links inside rendered pages. Must match what GitHub/Google/Apple have on
# file as the redirect host.
LOVELY_BASE_URL=http://localhost:8080

# --- Postgres --------------------------------------------------------------

# Postgres connection string. Local dev uses Homebrew Postgres on :5432
# with the `lovely_rs` role/db (created by ./bin/pg). The Docker compose
# stack uses lovely:LOVELY_DB_PASSWORD@postgres:5432/lovely.
LOVELY_DATABASE_URL=postgres://lovely_rs:lovely_rs@localhost:5432/lovely_rs

# Convenience var read by deploy/compose.yaml for the postgres service.
# Not consumed by lovely-server directly.
LOVELY_DB_PASSWORD=lovely

# --- Per-app SQLite --------------------------------------------------------

# Directory holding one SQLite file per user-created app. Created on demand.
# In Docker this is /data/apps and lives on a persistent volume.
LOVELY_SQLITE_DATA_DIR=./data/apps

# --- Sessions / cookies ----------------------------------------------------

# 32+ random bytes used to sign the session cookie. Generate with:
#     openssl rand -hex 32
# Rotating this value invalidates every active session — that's the goal
# during a security incident.
LOVELY_SESSION_SECRET=replace_me_with_64_hex_chars_of_entropy

# --- GitHub OAuth ----------------------------------------------------------

# Public client id (safe to commit if you really want to). Leave blank to
# disable the GitHub login route.
LOVELY_GITHUB_CLIENT_ID=
# Secret. NEVER commit a populated value.
LOVELY_GITHUB_CLIENT_SECRET=

# --- Google OAuth ----------------------------------------------------------

LOVELY_GOOGLE_CLIENT_ID=
# Secret.
LOVELY_GOOGLE_CLIENT_SECRET=

# --- Apple Sign In ---------------------------------------------------------

# The Services ID configured in the Apple Developer portal.
LOVELY_APPLE_CLIENT_ID=
# The 10-character developer team id.
LOVELY_APPLE_TEAM_ID=
# The 10-character key id of the .p8 file below.
LOVELY_APPLE_KEY_ID=
# Secret. Paste the contents of AuthKey_<KEY_ID>.p8 here, including the
# -----BEGIN PRIVATE KEY----- / -----END PRIVATE KEY----- lines. The
# server signs the OAuth client_secret JWT using this key.
# NOTE: The team's Apple developer account expires 2026-11-25 — see
# deploy/README.md for the rotation procedure.
LOVELY_APPLE_PRIVATE_KEY=

# --- Logging / tracing -----------------------------------------------------

# auto | json | pretty. Use json in production for structured logs.
LOVELY_LOG_FORMAT=auto
# tracing-subscriber env-filter directive.
LOVELY_LOG_LEVEL=info

# --- Static assets ---------------------------------------------------------

# Path to the static/ directory. The Docker image sets this to /opt/lovely/static.
LOVELY_STATIC_DIR=./static

# --- Dotenv toggle ---------------------------------------------------------

# Set to 1 to make lovely-server load this file at startup. Disabled by
# default so production environments cannot accidentally pick up a
# checked-out .env file.
LOVELY_DOTENV=1
